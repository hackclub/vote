# Prisma Postgres connection string
# Provision one at https://console.prisma.io (or run `npx prisma dev` locally)
DATABASE_URL=""

# Hack Club Auth OAuth app — register at https://auth.hackclub.com/developer/apps
# Redirect URI must be {APP_ORIGIN}/oauth/callback
HACKCLUB_CLIENT_ID=""
HACKCLUB_CLIENT_SECRET=""
APP_ORIGIN="http://localhost:5173"

# Airtable OAuth integration — register at https://airtable.com/create/oauth
# Redirect URI must be {APP_ORIGIN}/oauth/airtable/callback, with the scopes
# data.records:read, data.records:write, and schema.bases:read. Event admins
# connect their own Airtable account per event from the event settings page.
AIRTABLE_CLIENT_ID=""
AIRTABLE_CLIENT_SECRET=""

# Hack Club CDN API key (create one at https://cdn.hackclub.com) — screenshots
# are uploaded here so Airtable can fetch them as attachments
HACKCLUB_CDN_TOKEN=""

# Attend event API key (Attend dashboard → event → API key). Used to check
# participation at sign-in and to sync the roster. The event's slug doubles as
# its Attend slug, and the key is scoped to that single Attend event.
ATTEND_API_KEY=""

# Slack bot token (xoxb-…) with the users:read scope — used to resolve maker
# Slack display names (users.info). Names fall back to "Anonymous" without it.
SLACK_BOT_TOKEN=""

# Comma-separated emails that get admin access on sign-in
ADMIN_EMAILS=""

# Shared secret for the external HTTP API (POST /api/v1/events). Callers send
# it as "Authorization: Bearer <key>". Leave empty to disable the API entirely.
VOTE_API_KEY=""

# Sentry auth token — only needed at build time to upload source maps.
# Create one at https://hack-club-hcb.sentry.io/settings/auth-tokens/ (org: hack-club-hcb).
# Leave empty for local dev; builds without it just skip the source-map upload.
SENTRY_AUTH_TOKEN=""
